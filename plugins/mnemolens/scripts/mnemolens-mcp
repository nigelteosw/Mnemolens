#!/usr/bin/env bash
set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SERVER_DIR="$PLUGIN_DIR/server"

export MNEMOLENS_DB_PATH="${MNEMOLENS_DB_PATH:-$HOME/.codex/mnemolens/mnemolens.sqlite3}"

if command -v uv >/dev/null 2>&1; then
  export PYTHONPATH="$SERVER_DIR${PYTHONPATH:+:$PYTHONPATH}"
  exec uv run --project "$SERVER_DIR" python -m mnemolens.server
fi

if [ -x "$SERVER_DIR/.venv/bin/python" ]; then
  export PYTHONPATH="$SERVER_DIR${PYTHONPATH:+:$PYTHONPATH}"
  exec "$SERVER_DIR/.venv/bin/python" -m mnemolens.server
fi

cat >&2 <<EOF
uv was not found and the Mnemolens server environment is not installed.
Creating a plugin-local Python virtual environment now.
EOF

python3 -m venv "$SERVER_DIR/.venv" >&2
"$SERVER_DIR/.venv/bin/python" -m pip install --upgrade pip >&2
"$SERVER_DIR/.venv/bin/python" -m pip install -e "$SERVER_DIR" >&2
export PYTHONPATH="$SERVER_DIR${PYTHONPATH:+:$PYTHONPATH}"
exec "$SERVER_DIR/.venv/bin/python" -m mnemolens.server
